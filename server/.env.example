# Server Environment Configuration
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=changeme-in-production
CORS_ORIGIN=*

# AI Provider (OpenAI-compatible endpoint)
# For Qwen 3.5 via Ollama or vLLM:
AI_BASE_URL=http://localhost:11434
AI_MODEL=qwen3.5
AI_API_KEY=

# GitHub Integration
GITHUB_TOKEN=
GITHUB_ORG=

# Local repo storage (leave empty to use OS temp dir)
# Linux: /tmp/codeit-repos    Windows: auto-detected
# GIT_REPOS_DIR=/tmp/codeit-repos

# Boilerplate location (relative to server/)
BOILERPLATE_DIR=../boilerplate

# Docker workspace
DOCKER_ENABLED=false
DOCKER_IMAGE=codeit-workspace:latest
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=0.5

# Job settings
MAX_RETRIES=2

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=codeit
DB_PASSWORD=
DB_NAME=codeit

# Authentication
JWT_SECRET=change-me-to-a-long-random-string

# App domain (used to build per-user subdomain URLs)
# Set a wildcard A record (*.codeit.example.com → server IP) once in your DNS provider
CODEIT_DOMAIN=codeit.example.com
